{
  "name": "docs-harness",
  "version": "0.2.1",
  "description": "Agent native project document graph CLI.",
  "type": "module",
  "bin": {
    "docs-harness": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "install:local": "node scripts/package-local.mjs --install-global",
    "package:local": "node scripts/package-local.mjs",
    "prepack": "npm run clean && npm run build",
    "test": "npm run build && node --test test/*.test.js"
  },
  "keywords": [
    "agent",
    "cli",
    "documentation",
    "docs"
  ],
  "author": "",
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "ignore": "^7.0.5"
  }
}
